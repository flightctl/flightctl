{{ $decorator := (or .Vars.DecoratorName "TracedService") }}
{{ $tracerName := (or .Vars.TracerName "flightctl/service") }}
import (
	"context"
	"errors"

	"github.com/flightctl/flightctl/internal/domain"
	"github.com/flightctl/flightctl/internal/instrumentation/tracing"
	"go.opentelemetry.io/otel/attribute"
	"go.opentelemetry.io/otel/codes"
	"go.opentelemetry.io/otel/trace"
)

// {{$decorator}} wraps a {{.Interface.Type}} implementation with OpenTelemetry tracing.
type {{$decorator}} struct {
	inner {{.Interface.Type}}
}

// WrapWithTracing returns a {{.Interface.Type}} that wraps inner with tracing spans, or nil if inner is nil.
func WrapWithTracing(inner {{.Interface.Type}}) {{.Interface.Type}} {
	if inner == nil {
		return nil
	}
	return &{{$decorator}}{inner: inner}
}

func startSpan(ctx context.Context, method string) (context.Context, trace.Span) {
	return tracing.StartSpan(ctx, "{{$tracerName}}", method)
}

func endSpan(span trace.Span, st domain.Status) {
	span.SetAttributes(attribute.Int("status.code", int(st.Code)))

	if st.Status != "Success" {
		span.RecordError(errors.New(st.Message))
		span.SetStatus(codes.Error, st.Message)
	}

	span.End()
}
{{range $method := .Interface.Methods}}
func (_d *{{$decorator}}) {{$method.Declaration}} {
	ctx, span := startSpan(ctx, "{{$method.Name}}")
{{if not $method.HasResults}}
	_d.inner.{{$method.Call}}
	span.End()
	return
{{- else}}
{{- $last := last $method.Results}}
	{{$method.ResultsNames}} = _d.inner.{{$method.Call}}
{{- if eq $last.Type "domain.Status"}}
	endSpan(span, {{$last.Name}})
{{- else if $method.ReturnsError}}
	st := domain.StatusOK()
	if {{$last.Name}} != nil {
		st = domain.StatusInternalServerError({{$last.Name}}.Error())
	}
	endSpan(span, st)
{{- else}}
	endSpan(span, domain.StatusOK())
{{- end}}
	return {{$method.ResultsNames}}
{{- end}}
}
{{end}}
