# Build arguments for redhat-el9 flavor
# These args are used across all containerfiles for build and runtime base images

# Build-time base images (Red Hat enterprise editions)
BUILD_BASE_IMAGE=registry.redhat.io/ubi9/go-toolset:1.24.6
MINIMAL_BASE_IMAGE=registry.redhat.io/ubi9/ubi-minimal:9.7

RUNTIME_BASE_IMAGE=registry.redhat.io/flightctl/flightctl-base:9.7