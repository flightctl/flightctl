[Container]
Image=registry.access.redhat.com/ubi9/ubi-minimal
ContainerName=flightctl-ui-init
Volume=flightctl-api-certs:/source:ro
Volume=flightctl-ui-certs:/destination:rw
Volume=$CONFIG_OUTPUT_DIR/flightctl-ui/init.sh:/config/init.sh:ro,Z
Exec=/bin/sh /config/init.sh

[Service]
Type=oneshot
RemainAfterExit=false
TimeoutStartSec=5s
Restart=on-failure
RestartSec=5s

[Install]
WantedBy=flightctl.slice
