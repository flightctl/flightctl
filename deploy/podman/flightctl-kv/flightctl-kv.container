[Unit]
Description=Flight Control Key Value service
PartOf=flightctl.target

[Container]
ContainerName=flightctl-kv
Image={{ .Kv.Image }}:{{ .Kv.Tag }}
Pull=missing
Network=flightctl.network
AddHost=%H:host-gateway
Secret=flightctl-kv-password,type=env,target=REDIS_PASSWORD
Volume=/usr/share/flightctl/flightctl-kv/redis.conf:/etc/redis.conf:Z

[Service]
Type=notify
Restart=always
RestartSec=30

[Install]
WantedBy=flightctl.target
