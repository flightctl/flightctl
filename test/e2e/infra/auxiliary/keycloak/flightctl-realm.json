{
  "realm": "flightctl",
  "enabled": true,
  "requiredActions": [
    {
      "alias": "VERIFY_PROFILE",
      "name": "Verify Profile",
      "providerId": "VERIFY_PROFILE",
      "enabled": true,
      "defaultAction": false,
      "priority": 50,
      "config": {}
    }
  ],
  "clients": [
    {
      "clientId": "flightctl-client",
      "name": "flightctl-client",
      "enabled": true,
      "redirectUris": [
        "http://localhost:8080/callback"
      ],
      "webOrigins": ["+"],
      "publicClient": false,
      "secret": "e2e-flightctl-client-secret",
      "protocol": "openid-connect",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true
    }
  ],
  "users": [
    {
      "username": "testuser",
      "enabled": true,
      "email": "testuser@e2e.example.com",
      "firstName": "Test",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "testpass",
          "temporary": false
        }
      ],
      "groups": ["/org-default"],
      "realmRoles": ["default-roles-flightctl"]
    }
  ],
  "groups": [
    {
      "name": "org-default",
      "path": "/org-default"
    }
  ],
  "defaultRoles": ["default-roles-flightctl"]
}
